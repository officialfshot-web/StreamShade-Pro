{
  "manifest_version": 3,
  "name": "StreamShade Pro",
  "version": "2.0",
  "description": "Ultimate LookMovie enhancer - popup close, intro/outro skip, custom segments, speed control, stats",
  "permissions": ["storage", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://www.lookmovie2.to/*",
    "*://lookmovie2.to/*",
    "*://lookmovie.to/*",
    "*://www.lookmovie.to/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.lookmovie2.to/*",
        "*://lookmovie2.to/*",
        "*://lookmovie.to/*",
        "*://www.lookmovie.to/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
